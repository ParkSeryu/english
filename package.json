{
  "name": "english-review-app",
  "version": "0.1.0",
  "private": true,
  "description": "Mobile-first English expression memorization MVP with shared content and per-user progress.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:node": "vitest run --project node",
    "test:components": "vitest run --project jsdom",
    "test:watch": "vitest",
    "test:e2e": "playwright test --grep-invert @perf",
    "test:perf": "playwright test --grep @perf",
    "verify": "npm run clean:runtime && npm run lint && npm run typecheck && npm test && npm run build && npm run clean:runtime && npm run test:e2e",
    "verify:rls": "bash scripts/verify-rls-local.sh",
    "clean:runtime": "rm -rf .next test-results playwright-report",
    "verify:all": "npm run verify && npm run test:perf && npm run verify:rls"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.86.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "^15.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@next/eslint-plugin-next": "^15.5.0",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^20.19.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.0",
    "eslint-config-next": "^15.5.0",
    "jsdom": "^27.3.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
