# Supabase Auth + database (required outside local tests)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-or-anon-key

# Server-only: used by the protected Codex/assistant ingestion route.
# INGESTION_API_TOKEN is NOT an OpenAI/LLM provider key.
# It is any long random shared secret that lets the assistant call this app's save API.
# Never expose service role keys to the browser.
# INGESTION_API_TOKEN=replace-with-long-random-token
# INGESTION_OWNER_ID=00000000-0000-4000-8000-000000000001
# SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Server-only: direct Postgres URL used by Flyway-style migration scripts.
# Prefer a direct/session pooler URL that works with psql; never expose it to the browser.
# SUPABASE_DB_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres

# Optional: used only by Playwright smoke tests with the guarded in-memory store.
# Never set these in production or Vercel.
# E2E_MEMORY_STORE=1
# E2E_FAKE_USER_ID=00000000-0000-4000-8000-000000000001
